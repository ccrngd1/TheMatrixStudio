# TheMatrix Simulation Studio - Environment Configuration Example
# Copy this file to .env and fill in your API keys

# ==================== LiteLLM Model Configuration ====================
# Any LiteLLM model string: openai/gpt-4o, anthropic/..., bedrock/..., ollama/...
LITELLM_MODEL=bedrock/global.anthropic.claude-haiku-4-5-20251001-v1:0
LITELLM_TEMPERATURE=0.7
LITELLM_MAX_TOKENS=2048

# ==================== AWS Credentials (for Bedrock) ====================
# Required for Bedrock models and Nova Canvas avatar generation.
# Option A (recommended): Bedrock API key / bearer token
AWS_BEARER_TOKEN_BEDROCK=
# Option B: classic IAM access key pair
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ==================== OpenAI ====================
OPENAI_API_KEY=

# ==================== Anthropic ====================
ANTHROPIC_API_KEY=

# ==================== Simulation Defaults ====================
MAX_MESSAGES=20

# ==================== Storage ====================
DATA_DIR=./data

# ==================== Server Settings (Phase 1) ====================
MATRIX_PORT=8000
MATRIX_HOST=127.0.0.1

# ==================== Avatar Generation ====================
# Uses a Stability text-to-image model on Bedrock (Nova Canvas is retired).
# SD3.5 Large is served from us-west-2, which can differ from your text model region.
ENABLE_AVATARS=true
AVATAR_MODEL_ID=stability.sd3-5-large-v1:0
AVATAR_REGION=us-west-2
AVATAR_ASPECT_RATIO=1:1
