# TheMatrix Simulation Studio - Environment Configuration Example
# Copy this file to .env and fill in your API keys

# ==================== LiteLLM Model Configuration ====================
# Any LiteLLM model string: openai/gpt-4o, anthropic/..., bedrock/..., ollama/...
LITELLM_MODEL=bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0
LITELLM_TEMPERATURE=0.7
LITELLM_MAX_TOKENS=2048

# ==================== AWS Credentials (for Bedrock) ====================
# Required for Bedrock models and Nova Canvas avatar generation
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ==================== OpenAI ====================
OPENAI_API_KEY=

# ==================== Anthropic ====================
ANTHROPIC_API_KEY=

# ==================== Simulation Defaults ====================
MAX_MESSAGES=20

# ==================== Storage ====================
DATA_DIR=./data

# ==================== Server Settings (Phase 1) ====================
MATRIX_PORT=8000
MATRIX_HOST=127.0.0.1

# ==================== Avatar Generation ====================
ENABLE_AVATARS=true
AVATAR_MODEL_ID=amazon.nova-canvas-v1:0
AVATAR_WIDTH=512
AVATAR_HEIGHT=512
